<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F8FF">

    <!-- PANTALLA PRINCIPAL -->
    <ScrollView
        android:id="@+id/layoutPrincipal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center">

            <!-- TÍTULO -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:fontFamily="serif"
                android:text="✨ Meowmiaumotchi ✨"
                android:textColor="#FF6FA3"
                android:textSize="26sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ꕤ tu gatito virtual ꕤ"
                android:textSize="13sp"
                android:textColor="#FFB3C6"
                android:layout_marginBottom="16dp"/>

            <!-- TARJETA DEL GATO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌸 ☁️ 🌸"
                    android:textSize="18sp"
                    android:layout_marginBottom="8dp"/>

                <ImageView
                    android:id="@+id/ivGato"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/cat_normal1"
                    android:scaleType="fitCenter"
                    android:contentDescription="gatito"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😊 Tu gatito está feliz~"
                    android:textSize="15sp"
                    android:textColor="#FF6FA3"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDias"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ Día 1 de aventuras"
                    android:textSize="12sp"
                    android:textColor="#FFB3C6"/>

            </LinearLayout>

            <!-- TARJETA STATS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ᵕ̈ Estado de tu gatito"
                    android:textSize="14sp"
                    android:textColor="#FF6FA3"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- HAMBRE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="🍡"
                        android:textSize="18sp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Pancita"
                                android:textSize="12sp"
                                android:textColor="#888"/>
                            <TextView
                                android:id="@+id/tvHambreNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:textSize="12sp"
                                android:textColor="#FF6FA3"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <ProgressBar
                            android:id="@+id/pbHambre"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:max="100"
                            android:progress="100"
                            android:progressTint="#FFB3C6"
                            android:progressBackgroundTint="#FFE4EF"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- FELICIDAD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="💖"
                        android:textSize="18sp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Felicidad"
                                android:textSize="12sp"
                                android:textColor="#888"/>
                            <TextView
                                android:id="@+id/tvFelicidadNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:textSize="12sp"
                                android:textColor="#FF85C2"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <ProgressBar
                            android:id="@+id/pbFelicidad"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:max="100"
                            android:progress="100"
                            android:progressTint="#FF85C2"
                            android:progressBackgroundTint="#FFE4EF"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ENERGÍA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="18sp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Energía"
                                android:textSize="12sp"
                                android:textColor="#888"/>
                            <TextView
                                android:id="@+id/tvEnergiaNum"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="100%"
                                android:textSize="12sp"
                                android:textColor="#A78BFA"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <ProgressBar
                            android:id="@+id/pbEnergia"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:max="100"
                            android:progress="100"
                            android:progressTint="#A78BFA"
                            android:progressBackgroundTint="#EDE9FE"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- BOTONES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <!-- Comer -->
                <LinearLayout
                    android:id="@+id/btnComer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_pink"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍡"
                        android:textSize="26sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comer"
                        android:textSize="11sp"
                        android:textColor="#FF6FA3"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Jugar -->
                <LinearLayout
                    android:id="@+id/btnJugar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_purple"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎀"
                        android:textSize="26sp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jugar"
                        android:textSize="11sp"
                        android:textColor="#A78BFA"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Dormir / Despertar -->
                <LinearLayout
                    android:id="@+id/btnDormir"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_blue"
                    android:padding="14dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView
                        android:id="@+id/emojiBtnDormir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙"
                        android:textSize="26sp"/>
                    <TextView
                        android:id="@+id/tvBtnDormir"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dormir"
                        android:textSize="11sp"
                        android:textColor="#60A5FA"
                        android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>

            <!-- MENSAJE -->
            <TextView
                android:id="@+id/tvMensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#FF6FA3"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- OVERLAY ANIMACIÓN ACCIÓN -->
    <FrameLayout
        android:id="@+id/overlayAccion"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:gravity="center">

        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_background"
            android:padding="24dp">

            <ImageView
                android:id="@+id/ivAccionGato"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:scaleType="fitCenter"
                android:contentDescription="accion"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvAccionTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Comiendo!"
                android:textSize="20sp"
                android:textColor="#FF6FA3"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvAccionDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍡 ñam ñam~"
                android:textSize="14sp"
                android:textColor="#FFB3C6"/>

        </LinearLayout>
    </FrameLayout>

    <!-- PANTALLA DE MUERTE -->
    <LinearLayout
        android:id="@+id/layoutMuerto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#EE1a0a2e"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💔"
            android:textSize="60sp"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:id="@+id/ivGatoMuerto"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/cat_dead"
            android:scaleType="fitCenter"
            android:contentDescription="gatito muerto"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu gatito se fue..."
            android:textSize="24sp"
            android:textColor="#FFB3C6"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvDiasMuerto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vivió 1 día de aventuras 🌈"
            android:textSize="14sp"
            android:textColor="#9D8EC7"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descansa en el cielo gatuno~ 🌸"
            android:textSize="13sp"
            android:textColor="#7B6BA0"
            android:layout_marginBottom="40dp"/>

        <!-- BOTÓN REINICIAR -->
        <LinearLayout
            android:id="@+id/btnReiniciar"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_pink"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌸"
                android:textSize="30sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adoptar nuevo gatito"
                android:textSize="14sp"
                android:textColor="#FF6FA3"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Pantalla de bienvenida y darle nombre al gatito -->
    <LinearLayout
        android:id="@+id/layoutBienvenida"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#FFF0F8FF"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Bienvenida ✨"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FF6FA3"
            android:fontFamily="serif"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Un gatito te está esperando!"
            android:textSize="14sp"
            android:textColor="#FFB3C6"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:src="@drawable/cat_happy1"
            android:scaleType="fitCenter"
            android:contentDescription="gatito"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Cómo se llamará tu gatito?"
            android:textSize="15sp"
            android:textColor="#FF6FA3"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Campo de nombre -->
        <EditText
            android:id="@+id/etNombreGato"
            android:layout_width="260dp"
            android:layout_height="wrap_content"
            android:hint="Ej: Mochi, Luna, Nube..."
            android:textSize="16sp"
            android:textColor="#FF6FA3"
            android:textColorHint="#FFCCE0"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:gravity="center"
            android:maxLength="15"
            android:inputType="textPersonName"
            android:layout_marginBottom="24dp"/>

        <!-- Botón adoptar -->
        <LinearLayout
            android:id="@+id/btnAdoptar"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/btn_pink"
            android:padding="16dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐱"
                android:textSize="30sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Adoptar gatito!"
                android:textSize="14sp"
                android:textColor="#FF6FA3"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>